# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/orion-saas

# JWT Secret (CHANGE THIS IN PRODUCTION)
JWT_SECRET=change-this-to-a-random-32-char-string-in-production

# OpenAI API
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# DeepSeek API (Fallback)
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat

# Paystack
PAYSTACK_SECRET_KEY=sk_paystack_your_key_here
PAYSTACK_PUBLIC_KEY=pk_paystack_your_key_here

# Stripe
STRIPE_SECRET_KEY=sk_stripe_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
